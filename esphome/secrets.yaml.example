# ESPHome secrets — copy this file to secrets.yaml and fill in your values.
# secrets.yaml is listed in .gitignore and will NOT be committed.

# Wi-Fi credentials
wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# ESPHome API encryption key
# Generate a new key at: https://esphome.io/components/api.html
# Or run: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
trml_api_key: "your-base64-api-key-here"

# OTA update password
trml_ota_password: "your-ota-password-here"

# Fallback hotspot password (shown when device can't connect to Wi-Fi)
trml_ap_password: "your-ap-password-here"
